# CypherPilot — Environment Configuration
# ===================================
#
# Copy this file to .env and adjust values for your local environment:
#
#   cp .env.example .env
#
# Never commit .env to version control.  It is listed in .gitignore.

# ── Application ────────────────────────────────────────────────

# Application name (used in health check responses).
APP_NAME=CypherPilot

# Logging level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=DEBUG

# Allowed CORS origins (comma-separated).
# Include your frontend dev server URL here.
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Database ──────────────────────────────────────────────────

# Async database URL (for the FastAPI application).
# Uses asyncpg driver.  In Docker Compose the host is the service name.
# For local development without Docker, use localhost.
DATABASE_URL=postgresql+asyncpg://cypherpilot:cypherpilot@localhost:5432/cypherpilot

# Sync database URL (for Alembic migrations).
# Uses psycopg2 driver.  Use the same host as DATABASE_URL.
DATABASE_SYNC_URL=postgresql://cypherpilot:cypherpilot@localhost:5432/cypherpilot

# ── AI Provider ───────────────────────────────────────────────

# Active AI provider: "openrouter", "ollama", or leave empty.
AI__PROVIDER=openrouter

# OpenRouter API key (required when AI__PROVIDER=openrouter).
# Obtain from: https://openrouter.ai/keys
AI__OPENROUTER_API_KEY=

# OpenRouter model to use.
# See: https://openrouter.ai/models
AI__OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Ollama (alternative provider) ──────────────────────────────

# Base URL for local Ollama server.
AI__OLLAMA_BASE_URL=http://host.docker.internal:11434

# Ollama model to use.
AI__OLLAMA_MODEL=qwen3

# ── Future Providers ──────────────────────────────────────────

# Google Gemini (supported in future releases)
# AI__GEMINI_API_KEY=
# AI__GEMINI_MODEL=gemini-2.0-flash

# ── Session Retention ─────────────────────────────────────────

# Number of days to keep analysis sessions. Sessions older than this
# are eligible for automatic cleanup. Set to 0 to disable.
SESSION_RETENTION_DAYS=0